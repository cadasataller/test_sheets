<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Google Sheets Manager</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f0f4f8;
      color: #1a202c;
      min-height: 100vh;
    }
    header {
      background: #1a73e8;
      color: white;
      padding: 18px 32px;
      display: flex;
      align-items: center;
      gap: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.15);
    }
    header svg { width: 28px; height: 28px; }
    header h1 { font-size: 1.3rem; font-weight: 600; }
    .container { max-width: 860px; margin: 40px auto; padding: 0 20px; }

    .card {
      background: white;
      border-radius: 12px;
      padding: 28px;
      margin-bottom: 24px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.1);
    }
    .card h2 {
      font-size: 1rem;
      font-weight: 600;
      color: #1a73e8;
      margin-bottom: 18px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn {
      padding: 10px 22px;
      border: none;
      border-radius: 8px;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.2s;
    }
    .btn-primary { background: #1a73e8; color: white; }
    .btn-primary:hover { background: #1558b0; }
    .btn-success { background: #34a853; color: white; }
    .btn-success:hover { background: #267a3e; }
    .btn-danger  { background: #ea4335; color: white; }
    .btn-danger:hover  { background: #b5271e; }
    .btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .input-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    input[type="text"] {
      flex: 1;
      min-width: 180px;
      padding: 10px 14px;
      border: 1.5px solid #dde3ea;
      border-radius: 8px;
      font-size: 0.9rem;
      outline: none;
      transition: border 0.2s;
    }
    input[type="text"]:focus { border-color: #1a73e8; }

    .status-bar {
      padding: 10px 16px;
      border-radius: 8px;
      font-size: 0.85rem;
      margin-top: 10px;
      display: none;
    }
    .status-bar.show { display: block; }
    .status-bar.info    { background: #e8f0fe; color: #1a73e8; }
    .status-bar.success { background: #e6f4ea; color: #267a3e; }
    .status-bar.error   { background: #fce8e6; color: #b5271e; }

    #auth-section { text-align: center; padding: 40px 20px; }
    #auth-section p { color: #5f6368; margin-bottom: 20px; font-size: 0.95rem; }

    .sheet-id-display {
      background: #f8f9fa;
      border: 1.5px solid #dde3ea;
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 0.82rem;
      color: #5f6368;
      word-break: break-all;
      margin-top: 12px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.88rem;
      margin-top: 10px;
    }
    th {
      background: #1a73e8;
      color: white;
      padding: 10px 14px;
      text-align: left;
      font-weight: 500;
    }
    tr:nth-child(even) td { background: #f8f9fa; }
    td {
      padding: 9px 14px;
      border-bottom: 1px solid #e8eaed;
      color: #3c4043;
    }
    .empty-msg { text-align: center; color: #9aa0a6; padding: 30px; font-size: 0.9rem; }

    .tag {
      display: inline-block;
      background: #e8f0fe;
      color: #1a73e8;
      border-radius: 20px;
      padding: 3px 12px;
      font-size: 0.78rem;
      font-weight: 600;
      margin-left: 8px;
    }
    .actions-row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 10px; }
  </style>
</head>
<body>

<header>
  <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
    <rect x="3" y="3" width="18" height="18" rx="2" fill="white" fill-opacity="0.2" stroke="white" stroke-width="1.5"/>
    <line x1="3" y1="9" x2="21" y2="9" stroke="white" stroke-width="1.5"/>
    <line x1="3" y1="15" x2="21" y2="15" stroke="white" stroke-width="1.5"/>
    <line x1="9" y1="9" x2="9" y2="21" stroke="white" stroke-width="1.5"/>
  </svg>
  <h1>Google Sheets Manager</h1>
</header>

<div class="container">

  <!-- AUTH -->
  <div class="card" id="auth-section">
    <p>Inicia sesión con tu cuenta de Google para crear, editar y leer Sheets.</p>
    <button class="btn btn-primary" onclick="handleLogin()">🔐 Iniciar sesión con Google</button>
    <div id="auth-status" class="status-bar"></div>
  </div>

  <!-- MAIN (hidden until login) -->
  <div id="main-section" style="display:none">

    <!-- Crear Sheet -->
    <div class="card">
      <h2>📄 Crear nuevo Spreadsheet</h2>
      <div class="input-row">
        <input type="text" id="sheet-name" placeholder="Nombre del spreadsheet" value="Mi Spreadsheet"/>
      </div>
      <button class="btn btn-primary" onclick="createSheet()">Crear Sheet</button>
      <div id="create-status" class="status-bar"></div>
      <div id="sheet-id-display" class="sheet-id-display" style="display:none"></div>
    </div>

    <!-- Insertar datos -->
    <div class="card">
      <h2>✏️ Insertar / Actualizar datos <span class="tag">PUT</span></h2>
      <div class="input-row">
        <input type="text" id="insert-sheet-id" placeholder="Sheet ID (se llena automático al crear)"/>
        <input type="text" id="insert-range"    placeholder="Rango (ej: Sheet1!A1)" value="Sheet1!A1"/>
      </div>
      <div class="input-row">
        <input type="text" id="col-a" placeholder="Columna A" value="Nombre"/>
        <input type="text" id="col-b" placeholder="Columna B" value="País"/>
        <input type="text" id="col-c" placeholder="Columna C" value="Edad"/>
      </div>
      <div class="actions-row">
        <button class="btn btn-primary" onclick="insertData()">Insertar fila</button>
        <button class="btn btn-success" onclick="appendData()">➕ Agregar fila (append)</button>
      </div>
      <div id="insert-status" class="status-bar"></div>
    </div>

    <!-- Leer datos -->
    <div class="card">
      <h2>📊 Leer datos <span class="tag">GET</span></h2>
      <div class="input-row">
        <input type="text" id="read-sheet-id" placeholder="Sheet ID"/>
        <input type="text" id="read-range"    placeholder="Rango (ej: Sheet1!A1:Z100)" value="Sheet1!A1:Z100"/>
      </div>
      <button class="btn btn-primary" onclick="readData()">Leer Sheet</button>
      <div id="read-status" class="status-bar"></div>
      <div id="table-container"></div>
    </div>

    <div style="text-align:right; margin-bottom: 20px;">
      <button class="btn btn-danger" onclick="handleLogout()">Cerrar sesión</button>
    </div>
  </div>

</div>

<!-- Google Identity Services -->
<script src="https://accounts.google.com/gsi/client" async defer></script>

<script>
  const CLIENT_ID = "607252823419-qrsktr92hff3k3kjmm82t5st3aavhso6.apps.googleusercontent.com";
  const SCOPES    = "https://www.googleapis.com/auth/spreadsheets https://www.googleapis.com/auth/drive.file";
  let accessToken = null;
  let tokenClient = null;

  // ─── AUTH ────────────────────────────────────────────────────────────────

  window.onload = () => {
    tokenClient = google.accounts.oauth2.initTokenClient({
      client_id: CLIENT_ID,
      scope: SCOPES,
      callback: (response) => {
        if (response.error) {
          showStatus("auth-status", "Error al autenticar: " + response.error, "error");
          return;
        }
        accessToken = response.access_token;
        document.getElementById("auth-section").style.display = "none";
        document.getElementById("main-section").style.display = "block";
      }
    });
  };

  function handleLogin() {
    tokenClient.requestAccessToken();
  }

  function handleLogout() {
    if (accessToken) google.accounts.oauth2.revoke(accessToken);
    accessToken = null;
    document.getElementById("auth-section").style.display = "block";
    document.getElementById("main-section").style.display = "none";
    document.getElementById("table-container").innerHTML = "";
    document.getElementById("sheet-id-display").style.display = "none";
  }

  // ─── CREAR SHEET ─────────────────────────────────────────────────────────

  async function createSheet() {
    const name = document.getElementById("sheet-name").value.trim() || "Mi Spreadsheet";
    showStatus("create-status", "Creando spreadsheet...", "info");

    try {
      const res = await fetch("https://sheets.googleapis.com/v4/spreadsheets", {
        method: "POST",
        headers: {
          "Authorization": `Bearer ${accessToken}`,
          "Content-Type": "application/json"
        },
        body: JSON.stringify({
          properties: { title: name },
          sheets: [{ properties: { title: "Sheet1" } }]
        })
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error?.message || "Error desconocido");

      const sheetId = data.spreadsheetId;

      // Llenar campos de ID automáticamente
      document.getElementById("insert-sheet-id").value = sheetId;
      document.getElementById("read-sheet-id").value   = sheetId;

      const display = document.getElementById("sheet-id-display");
      display.style.display = "block";
      display.innerHTML = `✅ Sheet creado: <strong>${name}</strong><br>
        ID: <code>${sheetId}</code><br>
        <a href="https://docs.google.com/spreadsheets/d/${sheetId}" target="_blank">🔗 Abrir en Google Sheets</a>`;

      showStatus("create-status", "¡Spreadsheet creado exitosamente!", "success");
    } catch (e) {
      showStatus("create-status", "Error: " + e.message, "error");
    }
  }

  // ─── INSERTAR (PUT) ───────────────────────────────────────────────────────

  async function insertData() {
    const sheetId = document.getElementById("insert-sheet-id").value.trim();
    const range   = document.getElementById("insert-range").value.trim();
    const values  = getRowValues();

    if (!sheetId) return showStatus("insert-status", "Ingresa un Sheet ID", "error");

    showStatus("insert-status", "Insertando datos...", "info");

    try {
      const res = await fetch(
        `https://sheets.googleapis.com/v4/spreadsheets/${sheetId}/values/${encodeURIComponent(range)}?valueInputOption=RAW`,
        {
          method: "PUT",
          headers: {
            "Authorization": `Bearer ${accessToken}`,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ values: [values] })
        }
      );

      const data = await res.json();
      if (!res.ok) throw new Error(data.error?.message);
      showStatus("insert-status", `✅ Datos escritos en ${range}`, "success");
    } catch (e) {
      showStatus("insert-status", "Error: " + e.message, "error");
    }
  }

  // ─── APPEND (POST) ────────────────────────────────────────────────────────

  async function appendData() {
    const sheetId = document.getElementById("insert-sheet-id").value.trim();
    const range   = document.getElementById("insert-range").value.trim();
    const values  = getRowValues();

    if (!sheetId) return showStatus("insert-status", "Ingresa un Sheet ID", "error");

    showStatus("insert-status", "Agregando fila...", "info");

    try {
      const res = await fetch(
        `https://sheets.googleapis.com/v4/spreadsheets/${sheetId}/values/${encodeURIComponent(range)}:append?valueInputOption=RAW&insertDataOption=INSERT_ROWS`,
        {
          method: "POST",
          headers: {
            "Authorization": `Bearer ${accessToken}`,
            "Content-Type": "application/json"
          },
          body: JSON.stringify({ values: [values] })
        }
      );

      const data = await res.json();
      if (!res.ok) throw new Error(data.error?.message);
      showStatus("insert-status", "✅ Fila agregada correctamente", "success");
    } catch (e) {
      showStatus("insert-status", "Error: " + e.message, "error");
    }
  }

  // ─── LEER (GET) ───────────────────────────────────────────────────────────

  async function readData() {
    const sheetId = document.getElementById("read-sheet-id").value.trim();
    const range   = document.getElementById("read-range").value.trim();

    if (!sheetId) return showStatus("read-status", "Ingresa un Sheet ID", "error");

    showStatus("read-status", "Leyendo datos...", "info");

    try {
      const res = await fetch(
        `https://sheets.googleapis.com/v4/spreadsheets/${sheetId}/values/${encodeURIComponent(range)}`,
        { headers: { "Authorization": `Bearer ${accessToken}` } }
      );

      const data = await res.json();
      if (!res.ok) throw new Error(data.error?.message);

      const rows = data.values || [];
      renderTable(rows);
      showStatus("read-status", `✅ ${rows.length} fila(s) encontradas`, "success");
    } catch (e) {
      showStatus("read-status", "Error: " + e.message, "error");
    }
  }

  // ─── HELPERS ──────────────────────────────────────────────────────────────

  function getRowValues() {
    return [
      document.getElementById("col-a").value,
      document.getElementById("col-b").value,
      document.getElementById("col-c").value
    ];
  }

  function renderTable(rows) {
    const container = document.getElementById("table-container");
    if (!rows.length) {
      container.innerHTML = '<p class="empty-msg">No hay datos en este rango.</p>';
      return;
    }
    const [header, ...body] = rows;
    const ths = header.map(h => `<th>${h}</th>`).join("");
    const trs = body.map(row =>
      "<tr>" + header.map((_, i) => `<td>${row[i] ?? ""}</td>`).join("") + "</tr>"
    ).join("");

    container.innerHTML = `
      <table>
        <thead><tr>${ths}</tr></thead>
        <tbody>${trs || '<tr><td colspan="${header.length}" class="empty-msg">Sin filas de datos</td></tr>'}</tbody>
      </table>`;
  }

  function showStatus(id, msg, type) {
    const el = document.getElementById(id);
    el.textContent = msg;
    el.className = `status-bar show ${type}`;
  }
</script>
</body>
</html>
